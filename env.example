# Environment Variables Example
# Copy this file to .env and fill in the values

# AWS Credentials for Bedrock
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-west-2

# LangSmith configuration for tracing
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=dataset-creator-agent
LANGCHAIN_TRACING_V2=true

# PostgreSQL for LangGraph persistence
POSTGRES_URI=postgresql://username:password@localhost:5432/datasets

# Agent configuration
USE_EXPLICIT_GRAPH=true
MODEL_ID=anthropic.claude-3-7-sonnet-20250219-v1:0

# Web UI configuration
NEXT_PUBLIC_AGENT_NAME="Dataset Creator Agent"
NEXT_PUBLIC_AGENT_API_URL=/api/agent
NEXT_PUBLIC_LANGGRAPH_URL=/api/connect
NEXT_PUBLIC_AGENT_CONFIG_URL=/api/config

# HuggingFace Hub (optional)
HF_TOKEN=your_huggingface_token_here

# Application Settings
DEBUG=false
LOG_LEVEL=info
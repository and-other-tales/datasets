# Application Settings
NODE_ENV=production
PORT=8080
NEXT_TELEMETRY_DISABLED=1

# Agent API Settings
AGENT_API_URL=http://localhost:8000
# Set to 'websocket' or 'http' to determine connection method
AGENT_CONNECTION_TYPE=http

# Storage Settings
# Directory for storing conversation history and datasets
STORAGE_DIR=/gcs/dataset-creator

# Custom Settings
# Maximum number of simultaneous crawling tasks
MAX_CONCURRENT_TASKS=3
# Default crawl depth
DEFAULT_CRAWL_DEPTH=2
